# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
# Leave AZURE_OPENAI_API_KEY empty to use Azure AD (managed identity / az login)
AZURE_OPENAI_API_KEY=

# GoDaddy
# Use the production endpoint for real availability/pricing data.
# The OTE sandbox (https://api.ote-godaddy.com) returns FAKE data — canned
# prices and unreliable availability — so domains it reports as free may
# actually be taken. OTE and production use DIFFERENT key/secret pairs.
GODADDY_API_ENDPOINT=https://api.godaddy.com
GODADDY_API_KEY=
GODADDY_API_SECRET=
MAX_USD_PRICE=

# Azure Speech (optional; set VOICE_ON=true to enable)
VOICE_ON=false
AZURE_SPEECH_TTS_KEY=
AZURE_SPEECH_TTS_REGION=
